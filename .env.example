# Styx ENV-переменные. Полный список с дефолтами и описанием.
# Все имена с префиксом STYX_ (кроме DATABASE_URL — fallback).
# Альтернатива ENV — $HERMES_HOME/styx.json (тот же набор полей в
# snake_case, без префикса).

# ── Database ─────────────────────────────────────────────────────────
# PostgreSQL 18+ с расширением pgvector. Обязательный параметр.
STYX_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/styx
# DATABASE_URL=postgresql://...  # fallback если STYX_DATABASE_URL не задан

# ── Embedding ────────────────────────────────────────────────────────
# Ollama endpoint с embedding-моделью. embeddinggemma:300m-qat-q8_0
# (768-dim) — текущая рабочая модель; bge-m3 как fallback.
STYX_OLLAMA_URL=http://OLLAMA_HOST:11434
STYX_EMBEDDING_MODEL=embeddinggemma:300m-qat-q8_0
STYX_EMBEDDING_DIM=768
STYX_EMBEDDING_TIMEOUT_S=30.0

# IP-адрес Ollama-сервера для docker-compose extra_hosts. В compose
# контейнеры резолвят alias `ollama` через /etc/hosts на этот IP.
# Если Ollama локально на хосте — 127.0.0.1; если в LAN — IP сервера.
OLLAMA_HOST_IP=127.0.0.1

# ── LLM workers (qwen3:4b-local) ─────────────────────────────────────
# Структурированный JSON-out: importance, recall classifier, sentiment,
# batch consolidation. По умолчанию — та же Ollama что embedding.
STYX_LLM_URL=http://OLLAMA_HOST:11434
STYX_LLM_MODEL=qwen3:4b-local
STYX_LLM_TIMEOUT_S=60.0
STYX_LLM_MAX_ATTEMPTS=2
STYX_LLM_RATE_LIMIT_CAPACITY=4
STYX_LLM_RATE_LIMIT_REFILL_PER_S=1.0

# ── Sweep (lifecycle, периодические задачи воркера) ──────────────────
STYX_SWEEP_INTERVAL_S=3600.0
STYX_SWEEP_LOCK_TIMEOUT_S=1800.0

# ── Sentiment hot-path (волна 7d) ────────────────────────────────────
# VAD extraction inline в sync_turn. Fail-open на timeout.
STYX_SENTIMENT_ENABLED=1
STYX_SENTIMENT_TIMEOUT_S=0.8
STYX_EMOTIONAL_TICK_INTERVAL_S=60.0

# ── Recall classifier (волна 7c) ─────────────────────────────────────
STYX_CLASSIFIER_MIN_ASSISTANT_LENGTH=50
STYX_CLASSIFIER_MAX_RECALL_EVENTS_PER_TURN=20

# ── Recall threshold (волна 8) ───────────────────────────────────────
# Откалибровано под embeddinggemma. Не трогать без bench-suite.
# STYX_RECALL_MIN_SCORE=0.32
# STYX_RECALL_DIALOGUE_MIN_SCORE=0.6
# STYX_RECALL_MEMORY_LIMIT=6  # сколько memories попадает в salient-блок за turn

# ── Salient memories (волна 9) ───────────────────────────────────────
STYX_SALIENT_ENABLED=1
STYX_SALIENT_TIMEOUT_S=1.0
STYX_SALIENT_MIN_QUERY_LEN=20

# ── Drift detection (волна 10) ───────────────────────────────────────
STYX_DRIFT_ENABLED=1
STYX_DRIFT_THRESHOLD=0.4
STYX_FOCUS_WINDOW_SIZE=3

# ── Pre-LLM focus inject (волна 15; канал self_state — волна 35) ─────
STYX_PRE_LLM_INJECT_ENABLED=1
STYX_SELF_STATE_ENABLED=1
STYX_SELF_STATE_MIN_NORM=0.2
STYX_SELF_STATE_MAX_AGE_S=900.0

# ── Temporal isolation (волна 14, 10a) ───────────────────────────────
STYX_TURN_STATE_TTL_S=60.0

# ── Batch consolidation (волна 14) ───────────────────────────────────
STYX_BATCH_CONSOLIDATION_ENABLED=1
STYX_BATCH_TICK_INTERVAL_S=60.0
STYX_BATCH_TRIGGER_MESSAGES=20
STYX_BATCH_TRIGGER_INTERVAL_S=1200
STYX_BATCH_PERIOD_GAP_S=21600
STYX_BATCH_SENTIMENT_ENABLED=1

# ── Hot-tier (волна 11) ──────────────────────────────────────────────
STYX_HOT_TIER_ENABLED=1
STYX_HOT_TIER_TTL_S=300.0
STYX_HOT_TIER_LRU_BOUND=100

# ── Eviction relevance-aware (волна 12) ──────────────────────────────
STYX_EVICTION_RELEVANCE_ENABLED=1
STYX_EVICTION_RELEVANCE_KEEP_K=2
STYX_EVICTION_RELEVANCE_THRESHOLD=0.4

# ── Working set state persistence (волна 13) ─────────────────────────
STYX_WORKING_SET_PERSISTENCE_ENABLED=1
STYX_WORKING_SET_SAVE_INTERVAL_S=30.0
STYX_WORKING_SET_TTL_S=86400.0

# ── Healthz endpoint (волна 16) ──────────────────────────────────────
# port=0 отключает HTTP-сервер. В Docker — bind=0.0.0.0.
STYX_HEALTHZ_PORT=8788
STYX_HEALTHZ_BIND=127.0.0.1
STYX_HEALTHZ_LIVENESS_THRESHOLD_S=120.0
STYX_HEALTHZ_READINESS_THRESHOLD_S=300.0

# ── HTTP API daemon (FastAPI app + worker pool в одном процессе) ────
# bind=127.0.0.1 — loopback-only по умолчанию. На non-loopback bind
# (0.0.0.0 / внешний IP) STYX_HTTP_TOKEN обязателен, иначе daemon
# не стартует. См. docs/HTTP_API.md § Auth.
STYX_HTTP_BIND=127.0.0.1
STYX_HTTP_PORT=8788
# STYX_HTTP_TOKEN=replace-with-strong-random-secret

# ── Logging (волна 16) ───────────────────────────────────────────────
# text — для dev / отладки (читать глазами).
# json — для production (vector/fluentbit парсит без regex'ов).
STYX_LOG_FORMAT=text
STYX_LOG_LEVEL=INFO
