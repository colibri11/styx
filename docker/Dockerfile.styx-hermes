# Styx Hermes-shim image — наследует Hermes Agent + styx-core + styx-hermes.
#
# Базовый образ — официальный s6-overlay nousresearch/hermes-agent.
# В нём gateway НЕ бинарь на PATH: его поднимает s6-супервизор, а docker
# CMD `["gateway","run"]` маршрутизируется main-wrapper.sh в
# `s6-setuidgid hermes hermes gateway run`. Поэтому Styx-bootstrap
# интегрируется НАТИВНО как s6 cont-init.d hook (см. ниже), а НЕ как
# entrypoint-wrapper с `exec gateway` (это давало exit 127 на s6-образе).
# См. .design/context/decisions.md § 15 + § 48.
#
# Build:
#   docker compose -f docker/docker-compose.test.yml build hermes-styx
#   (HERMES_IMAGE передаётся из compose; для прода —
#    --build-arg HERMES_IMAGE=nousresearch/hermes-agent:v2026.5.29.2)
#
# ВАЖНО: HERMES_IMAGE обязан быть s6-overlay образом. Bootstrap кладётся в
# /etc/cont-init.d/ — этот механизм есть только в s6. На не-s6 базе (старый
# tini hermes-agent:latest) cont-init.d не выполнится → setup+patch не
# отработают → Styx молча неактивен (контейнер стартует без ошибки).

ARG HERMES_IMAGE=nousresearch/hermes-agent:v2026.5.29.2
FROM ${HERMES_IMAGE}

USER root

# Bootstrap как s6 cont-init.d hook: s6 выполняет /etc/cont-init.d/* как
# root ДО старта user-сервисов, в лексикографическом порядке. Префикс
# `30-` ставит нас ПОСЛЕ штатных 01-hermes-setup / 015-supervise-perms /
# 02-reconcile-profiles (config.yaml к этому моменту уже создан). Скрипт
# делает только setup+patch, БЕЗ запуска gateway — его поднимает s6 сам.
COPY --chmod=0755 docker/styx-bootstrap.sh /etc/cont-init.d/30-styx-bootstrap

# styx-core + styx-hermes pip-packages. .dockerignore исключает
# .venv/.git/__pycache__/etc.
COPY --chown=hermes:hermes packages/styx-core /opt/styx-core/
COPY --chown=hermes:hermes packages/styx-hermes /opt/styx-hermes/

# Установка в Hermes venv:
# - Hermes использует uv (не pip) — venv не имеет /opt/hermes/.venv/bin/pip.
#   Используем `/usr/local/bin/uv pip install` чтобы ставить в нужный venv
#   через VIRTUAL_ENV.
# - --no-deps: Hermes уже привнёс openai/anthropic/yaml/etc через свой
#   `uv pip install -e ".[all]"`; deps Styx указаны явно ниже.
# - psycopg/fastapi/uvicorn/pydantic/pydantic-settings/httpx/requests —
#   deps styx-core + styx-hermes, которых нет в Hermes base.
ENV VIRTUAL_ENV=/opt/hermes/.venv
RUN /usr/local/bin/uv pip install --no-deps -e /opt/styx-core && \
    /usr/local/bin/uv pip install --no-deps -e /opt/styx-hermes && \
    /usr/local/bin/uv pip install --no-cache \
        "psycopg[binary]>=3.2" \
        "psycopg-pool>=3.2" \
        "fastapi>=0.115" \
        "uvicorn[standard]>=0.32" \
        "pydantic>=2.10" \
        "pydantic-settings>=2.7" \
        "httpx>=0.27" \
        "requests>=2.32" \
        "pytest>=8.0" \
        "pytest-asyncio>=0.24" \
        "pypdf>=4.0" \
        "python-docx>=1.1" \
        "openpyxl>=3.1"

# ENTRYPOINT наследуется от base: s6 `/init` → main-wrapper.sh, который
# маршрутизирует docker CMD под `s6-setuidgid hermes`. CMD по умолчанию
# в проде — `["gateway","run"]`; в test-стеке — `["sleep","infinity"]`
# (см. docker-compose.test.yml). styx-bootstrap из CMD убран —
# он отрабатывает как cont-init.d hook ещё до маршрутизации CMD.
USER root
