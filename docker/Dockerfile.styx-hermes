# Styx Hermes-shim image — наследует Hermes Agent + styx-core + styx-hermes.
#
# Базовый образ — официальный s6-overlay nousresearch/hermes-agent.
# В нём gateway НЕ бинарь на PATH: его поднимает s6-супервизор, а docker
# CMD `["gateway","run"]` маршрутизируется main-wrapper.sh в
# `s6-setuidgid hermes hermes gateway run`.
# См. .design/context/decisions.md § 15 + § 48 + § 51.
#
# ── ORPHAN-МОДЕЛЬ (волна 33) ──────────────────────────────────────────
# Чистый образ оставляет Styx ДОСТУПНЫМ, но СИРОТОЙ: ни один профиль не
# подключён к Styx, включая базовый. Все профили работают на штатной
# памяти Hermes до явного attach.
#
#   • Доступность: bundled memory-shim лежит в образе под
#     /opt/hermes/plugins/memory/styx-memory/ (COPY ниже). Bundled-каталоги
#     обнаруживаются Hermes БЕЗУСЛОВНО (нужен лишь <name>/__init__.py),
#     загрузка через spec_from_file_location — дефис в имени переживает.
#     Это делает StyxMemoryProvider обнаружимым из ЛЮБОГО профиля, без
#     per-profile/per-base shim-install.
#   • Discovery ≠ attach. Провайдер лишь *обнаруживается*; он грузится
#     и используется, только когда в config.yaml профиля стоит
#     `memory.provider: styx-memory`. На orphan-профиле этого ключа нет →
#     shim не грузится, нулевой overhead, нет сайд-эффектов. Поэтому
#     bundled shim НЕ нарушает orphan-инвариант.
#   • Подключение — отдельный явный идемпотентный шаг, НЕ при старте
#     контейнера. Выполняется командой
#       styx-hermes-setup --attach [--profile <name>]
#     (через `docker exec`). Она патчит config.yaml целевого профиля
#     (memory.provider/plugins.enabled/context.engine) + бэкап + печатает
#     required-рестарт. Авто-патча на старте больше НЕТ (прежний
#     cont-init.d/30-styx-bootstrap ретайрен).
#
# Build:
#   docker compose -f docker/docker-compose.test.yml build hermes-styx
#   (HERMES_IMAGE передаётся из compose; для прода —
#    --build-arg HERMES_IMAGE=nousresearch/hermes-agent:v2026.5.29.2)

ARG HERMES_IMAGE=nousresearch/hermes-agent:v2026.5.29.2
FROM ${HERMES_IMAGE}

USER root

# styx-core + styx-hermes pip-packages. .dockerignore исключает
# .venv/.git/__pycache__/etc.
COPY --chown=hermes:hermes packages/styx-core /opt/styx-core/
COPY --chown=hermes:hermes packages/styx-hermes /opt/styx-hermes/

# Установка в Hermes venv:
# - Hermes использует uv (не pip) — venv не имеет /opt/hermes/.venv/bin/pip.
#   Используем `/usr/local/bin/uv pip install` чтобы ставить в нужный venv
#   через VIRTUAL_ENV.
# - --no-deps: Hermes уже привнёс openai/anthropic/yaml/etc через свой
#   `uv pip install -e ".[all]"`; deps Styx указаны явно ниже.
# - psycopg/fastapi/uvicorn/pydantic/pydantic-settings/httpx/requests —
#   deps styx-core + styx-hermes, которых нет в Hermes base.
ENV VIRTUAL_ENV=/opt/hermes/.venv
RUN /usr/local/bin/uv pip install --no-deps -e /opt/styx-core && \
    /usr/local/bin/uv pip install --no-deps -e /opt/styx-hermes && \
    /usr/local/bin/uv pip install --no-cache \
        "psycopg[binary]>=3.2" \
        "psycopg-pool>=3.2" \
        "fastapi>=0.115" \
        "uvicorn[standard]>=0.32" \
        "pydantic>=2.10" \
        "pydantic-settings>=2.7" \
        "httpx>=0.27" \
        "requests>=2.32" \
        "pytest>=8.0" \
        "pytest-asyncio>=0.24" \
        "pypdf>=4.0" \
        "python-docx>=1.1" \
        "openpyxl>=3.1"

# Bundled memory-shim (orphan-модель, волна 33). Лежит ПОСЛЕ установки
# styx-пакетов: `__init__.py` шима делает `from styx_hermes.memory_plugin
# import register`, что резолвится против pip-установленного styx_hermes
# (см. RUN выше). Каталог bundled под /opt/hermes/plugins/memory/<name>/
# обнаруживается Hermes безусловно (нужен лишь <name>/__init__.py),
# грузится через spec_from_file_location — дефис в имени ОК. Делает
# StyxMemoryProvider обнаружимым из любого профиля; attach отдельной
# командой (см. шапку).
COPY --chown=hermes:hermes packages/styx-hermes/src/styx_hermes/resources/plugins/styx-memory /opt/hermes/plugins/memory/styx-memory/

# ENTRYPOINT наследуется от base: s6 `/init` → main-wrapper.sh, который
# маршрутизирует docker CMD под `s6-setuidgid hermes`. CMD по умолчанию
# в проде — `["gateway","run"]`; в test-стеке — `["sleep","infinity"]`
# (см. docker-compose.test.yml). Авто-attach при старте контейнера нет —
# Styx остаётся сиротой до явной команды `styx-hermes-setup --attach`.
USER root
